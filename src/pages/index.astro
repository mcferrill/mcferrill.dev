---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="max-w-6xl mx-auto min-h-screen lg:flex">
    <!-- Sidebar -->
    <aside
      class="bg-stone-50 dark:bg-stone-800/40 lg:min-h-screen lg:w-80 lg:shrink-0 lg:sticky lg:top-0 text-center p-8 lg:p-10 flex flex-col items-center"
    >
      <img
        class="block rounded-full mx-auto w-32 h-32 lg:w-56 lg:h-56 object-cover shadow-lg ring-2 ring-blue-lighter dark:ring-blue-dark transition-transform hover:scale-[1.02]"
        alt=""
        width={250}
        height={250}
        src="/profile.jpg"
      />
      <h3 class="text-lg font-semibold mt-4">Micah Ferrill</h3>
      <h1 class="text-3xl lg:text-4xl font-bold mt-6 mb-3">Hi!</h1>
      <p class="text-stone-600 dark:text-stone-400 leading-relaxed">
        I&apos;m Micah, and I make software for desktop, web, and mobile.
      </p>
      <div class="flex flex-row justify-between w-48 max-w-full my-8">
        <a
          href="https://github.com/mcferrill"
          title="GitHub"
          class="text-stone-400 hover:text-blue transition-colors"
        >
          <img
            width={32}
            height={32}
            alt="Github"
            src="/github.svg"
            class="opacity-70 hover:opacity-100 dark:invert transition-opacity"
          />
        </a>
        <a
          href="https://www.linkedin.com/in/mcferrill/"
          title="LinkedIn"
          class="text-stone-400 hover:text-blue transition-colors"
        >
          <img
            width={32}
            height={32}
            alt="LinkedIn"
            src="/linkedin.svg"
            class="opacity-70 hover:opacity-100 dark:invert transition-opacity"
          />
        </a>
        <a
          href="https://twitter.com/mcferrill"
          title="Twitter"
          class="text-stone-400 hover:text-blue transition-colors"
        >
          <img
            width={32}
            height={32}
            alt="Twitter"
            src="/twitter.svg"
            class="opacity-70 hover:opacity-100 dark:invert transition-opacity"
          />
        </a>
      </div>
    </aside>

    <!-- Content -->
    <div class="flex-1 p-8 lg:p-12 space-y-12">

      <!-- Expertise -->
      <section>
        <h2 class="text-2xl font-bold mb-4 text-blue">
          Expertise
        </h2>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1.5 bg-blue-lighter dark:bg-blue-light text-blue-dark text-sm font-medium rounded-full">
            Python (Django, Flask, scipy)
          </span>
          <span class="px-3 py-1.5 bg-blue-lighter dark:bg-blue-light text-blue-dark text-sm font-medium rounded-full">
            Javascript (React, React-Native/Expo, Nodejs, Vue, jQuery)
          </span>
          <span class="px-3 py-1.5 bg-blue-lighter dark:bg-blue-light text-blue-dark text-sm font-medium rounded-full">
            Modern software tooling (Docker, Git, CI/CD)
          </span>
          <span class="px-3 py-1.5 bg-blue-lighter dark:bg-blue-light text-blue-dark text-sm font-medium rounded-full">
            Web Development (HTML, CSS, Tailwind, Less, SASS)
          </span>
          <span class="px-3 py-1.5 bg-blue-lighter dark:bg-blue-light text-blue-dark text-sm font-medium rounded-full">
            Library development (in Python, C/C++, C#)
          </span>
          <span class="px-3 py-1.5 bg-blue-lighter dark:bg-blue-light text-blue-dark text-sm font-medium rounded-full">
            Cybersecurity (Security+)
          </span>
        </div>
      </section>

      <!-- Work History -->
      <section>
        <h2 class="text-2xl font-bold mb-6 text-blue">
          Relevant Work History
        </h2>
        <div class="space-y-6">

          <!-- FiveQ -->
          <div class="bg-white dark:bg-stone-800/50 rounded-xl shadow-sm border border-stone-200 dark:border-stone-700/50 p-6 border-l-4 border-l-blue">
            <h3 class="font-bold text-lg">Software Engineer @ FiveQ</h3>
            <p class="text-sm text-stone-500 dark:text-stone-400 mt-1">2022 - present</p>
            <ul class="mt-3 space-y-2 text-stone-700 dark:text-stone-300 list-disc pl-5">
              <li>
                Standardized several high-traffic Django sites to use modernized 
                dependency management.
              </li>
              <li>
                Led a department restructuring to emphasize small, cross-functional
                teams.
              </li>
              <li>
                Rewrote frontend apps for an internet radio service from proprietary
                javascript to Remix.
              </li>
              <li>Rewrote and updated several mobile apps in React Native/Expo.</li>
            </ul>
          </div>

          <!-- Avionics -->
          <div class="bg-white dark:bg-stone-800/50 rounded-xl shadow-sm border border-stone-200 dark:border-stone-700/50 p-6 border-l-4 border-l-blue">
            <h3 class="font-bold text-lg">
              Software Engineer @ Avionics Test and Analysis Corporation
            </h3>
            <p class="text-sm text-stone-500 dark:text-stone-400 mt-1">2010 - 2022</p>
            <ul class="mt-3 space-y-2 text-stone-700 dark:text-stone-300 list-disc pl-5">
              <li>
                Built Visual Studio Code plugin for a telemetry configuration format
                (TMATS).
              </li>
              <li>
                Developed software to simulate F-16 pilot interface for lab testing
                missile prototypes.
              </li>
              <li>Served as Security Manager for classified systems.</li>
              <li>
                Developed open-source libraries and tools for parsing binary data in
                Python and C.
              </li>
              <li>Wrote weather data visualization tool for C5 radar logs.</li>
              <li>
                Rewrote and customized QML (Qt) and Javascript code for F-16 test
                program.
              </li>
              <li>
                Containerized multiple legacy and prototype software applications.
              </li>
              <li>
                Presented several technical papers at industry conferences on
                open-source software and containerization.
              </li>
            </ul>
          </div>

          <!-- Independent -->
          <div class="bg-white dark:bg-stone-800/50 rounded-xl shadow-sm border border-stone-200 dark:border-stone-700/50 p-6 border-l-4 border-l-blue">
            <h3 class="font-bold text-lg">
              Independent Software Developer & Author
            </h3>
            <p class="text-sm text-stone-500 dark:text-stone-400 mt-1">2005 - Present</p>
            <ul class="mt-3 space-y-2 text-stone-700 dark:text-stone-300 list-disc pl-5">
              <li>
                Built various new and updated websites for direct contracts and web
                firms.
              </li>
              <li>
                Wrote and consulted on multiple articles including one published on
                linux.com and a book on android development with python.
              </li>
              <li>
                Developed neighborhood watch software to deliver law enforcement
                alerts via text message (SMS).
              </li>
              <li>
                Developed iPad app for building floorplan layouts for print services
                company.
              </li>
            </ul>
          </div>

        </div>
      </section>
    </div>
  </main>
</Layout>
