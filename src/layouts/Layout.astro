---
import "../styles/globals.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Micah Ferrill - Software/Web Developer</title>
    <meta
      name="description"
      content="Micah Ferrill builds software for desktop, web, and mobile. Python, JavaScript, React, and more."
    />
    <meta property="og:title" content="Micah Ferrill - Software/Web Developer" />
    <meta
      property="og:description"
      content="Software engineer specializing in Python, JavaScript, and modern web technologies."
    />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-stone-900 dark:bg-stone-900 dark:text-stone-100 antialiased">
    <slot />
  </body>
